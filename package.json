{
  "name": "openclaw-ai-browser",
  "private": true,
  "version": "0.1.13",
  "type": "module",
  "main": "host/electron/main.mjs",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:web": "vite --port=3000 --strictPort --host=127.0.0.1",
    "dev:electron": "wait-on tcp:3000 && electron .",
    "icons:generate": "zsh ./scripts/generate-icons.sh",
    "build": "vite build",
    "dist": "npm run icons:generate && npm run build && electron-builder --mac dmg",
    "electron:start": "npm run build && SABRINA_RENDERER_SOURCE=dist electron .",
    "preview": "vite preview",
    "clean": "rm -rf dist release .playwright-cli",
    "relay:dev": "node ./packages/sabrina-relay-dev/src/server.mjs",
    "test:runtime": "node --test ./shared/localization.test.mjs ./runtime/browser/BrowserContextPackageService.test.mjs ./runtime/browser/BrowserSourceAvailabilityService.test.mjs ./runtime/browser/BrowserTabStateSupport.test.mjs ./runtime/browser/GenTabCodingService.test.mjs ./runtime/browser/GenTabGenerationService.test.mjs ./runtime/browser/GenTabStore.test.mjs ./runtime/browser/PageContextService.test.mjs ./runtime/browser/ActionGate.test.mjs ./runtime/browser/BrowserAgentPromptService.test.mjs ./runtime/browser/PageNarratorService.test.mjs ./runtime/browser/PageLocatorService.test.mjs ./runtime/browser/PageOverlayService.test.mjs ./runtime/browser/BrowserAgent.test.mjs ./runtime/browser/BrowserAgentCapability.test.mjs ./runtime/threads/ThreadTurnService.test.mjs ./runtime/turns/TurnEngine.test.mjs ./runtime/turns/TurnJournalStore.test.mjs ./runtime/openclaw/BrowserSkillCapabilityService.test.mjs ./runtime/openclaw/BrowserSkillInputPolicyService.test.mjs ./runtime/openclaw/ModelStateService.test.mjs ./runtime/openclaw/OpenClawDriverRegistry.test.mjs ./runtime/openclaw/OpenClawPresentationService.test.mjs ./runtime/openclaw/OpenClawRuntimeService.test.mjs ./runtime/openclaw/OpenClawSkillPayloadService.test.mjs ./runtime/openclaw/OpenClawStateModel.test.mjs ./runtime/openclaw/SabrinaRemotePairingService.test.mjs ./runtime/openclaw/SkillCatalogService.test.mjs ./runtime/openclaw/SkillTraceService.test.mjs ./runtime/openclaw/OpenClawTransportContext.test.mjs ./runtime/openclaw/SabrinaMemoryBridgeService.test.mjs ./runtime/openclaw/SabrinaProtocol.test.mjs ./runtime/openclaw/relay/SabrinaRelayRpcService.test.mjs ./packages/openclaw-plugin-sabrina/src/bridge-client.test.mjs ./packages/openclaw-plugin-sabrina/src/relay-worker.test.mjs",
    "test:electron-smoke": "node --test ./host/electron/ThreadIpcActionService.test.mjs ./host/electron/ThreadTurnSmoke.test.mjs ./host/electron/GenTabIpcActionService.test.mjs",
    "lint": "tsc --noEmit",
    "check:architecture": "node ./scripts/check-architecture-invariants.mjs",
    "acceptance": "node ./scripts/run-acceptance.mjs",
    "acceptance:json": "node ./scripts/run-acceptance.mjs --json"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "playwright-core": "^1.59.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0",
    "use-stick-to-bottom": "^1.1.3",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^35.1.4",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "ai.sabrina.browser",
    "productName": "Sabrina",
    "icon": "build/icon.icns",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "host/**/*",
      "packages/**/*",
      "runtime/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    }
  }
}
